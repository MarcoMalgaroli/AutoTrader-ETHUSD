{
    "symbol": "ETHUSD",
    "print_width": 100,

    "paths": {
        "dataset_raw": "datasets/raw",
        "dataset_final": "datasets/final"
    },

    "trading": {
        "lookahead": 4
    },

    "trading_10": {
        "atr_mult": 1.5,
        "threshold": 0.35,
        "confidence_thresholds": {
            "low_max": 0.45,
            "avg_max": 0.55
        },
        "position_sizes": {
            "low": 0.005,
            "avg": 0.01,
            "high": 0.04
        }
    },

